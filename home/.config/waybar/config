{
    "layer": "top",
    "position": "top",
    "height": 30, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)

    "modules-left": ["sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": [
        "idle_inhibitor",
        "custom/player", "pulseaudio", "backlight",
        "cpu", "memory", "temperature", "battery", "network",
        "sway/language", "clock", "tray"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}: {icon}",
        "format-icons": {
            "1": "ΎΕι",
            "2": "ΎΚρ",
            "3": "ΎΕκ",
            "4": "ΎΗ╝",
            "7": "έεΟ",
            "10": "ΎΒ╡",
            "urgent": "ΎΒς",
            "focused": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "sway/window": {
        "max-length": 200,
        "separate-outputs": true
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
	"custom/player": {
		"format": "{icon} {}",
		"format-icons": {
			"Playing": "≤░ΟΙ ",
			"Paused": "≤░Πν "
		},
		"return-type": "json",
		"exec": "playerctl -a metadata --format '{\"text\": \"{{playerName}}: {{artist}} - {{markup_escape(title)}}\", \"tooltip\": \"{{markup_escape(title)}} - {{markup_escape(album)}}\", \"class\": \"{{status}}\", \"alt\": \"{{status}}\" }' -F",
		"max-length": 30,
		"on-click": "playerctl play-pause"
	},
    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "≤░ζθ {icon}ΎΛΦ {format_source}",
        "format-muted": "≤░ζθ {format_source}",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "≤░ΜΜ",
            "headset": "≤░ΜΜ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        "format": "{icon}",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    "cpu": {
        "format": "{usage}% ΎΜδ",
        "tooltip": false,
        "states": {
            "warning": 80,
            "critical": 99
        }
    },
    "memory": {
        "format": "{used:0.1f}GiB ΎΔΚ",
        "tooltip-format": "{used:0.1f}GiB / {total:0.1f}GiB",
        "states": {
            "warning": 90,
            "critical": 95
        }
    },
    "temperature": {
        "critical-threshold": 80,
        "warning-threshold": 70,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ≤░ΓΕ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
        "format-ethernet": "≤░ΙΑ",
        "format-wifi": "{icon} {signalStrength}%",
        "format-linked": "≤░ΙΒ",
        "format-disconnected": "≤░ςΟ",
        "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
        "tooltip-format-ethernet": "≤░ΙΑ  {ifname}\n  {ipaddr}/{cidr}\n≤░ΙΒ  {gwaddr}",
        "tooltip-format-wifi": "≤░νρ  {essid}\n  {signalStrength}% ({signaldBm} dBm)\n  {ifname}  {ipaddr}/{cidr}\n≤░ΙΒ  {gwaddr}",
        "tooltip-format-disconnected": "Disconnected"
    },
    "clock": {
        "format": "{:%m-%d %b %H:%M}",
        "tooltip-format": "{:%Y-%m-%d}",
        "format-alt": "{:%Y-%m-%d %B %H:%M}"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    }
}
