{
    "layer": "top",
    "position": "top",
    "height": 30, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)

    "modules-left": ["sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": [
        "idle_inhibitor",
        "custom/player", "pulseaudio", "backlight",
        "cpu", "memory", "temperature",
        "sway/language", "network",
        "battery", "clock", "tray"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}: {icon}",
        "format-icons": {
            "1": "пД†",
            "2": "пЙ®",
            "3": "пД°",
            "4": "пЖЉ",
            "7": "вЬО",
            "10": "пБµ",
            "urgent": "пБ™",
            "focused": "пЖТ",
            "default": "пДС"
        }
    },
    "sway/window": {
        "max-length": 200,
        "separate-outputs": true
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пБЃ",
            "deactivated": "пБ∞"
        }
    },
	"custom/player": {
		"format": "{icon} {}",
		"format-icons": {
			"Playing": "у∞ОИ ",
			"Paused": "у∞П§ "
		},
		"return-type": "json",
		"exec": "playerctl -a metadata --format '{\"text\": \"{{playerName}}: {{artist}} - {{markup_escape(title)}}\", \"tooltip\": \"{{markup_escape(title)}} - {{markup_escape(album)}}\", \"class\": \"{{status}}\", \"alt\": \"{{status}}\" }' -F",
		"max-length": 30,
		"on-click": "playerctl play-pause"
	},
    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
        "format-bluetooth-muted": "у∞ЭЯ {icon}пКФ {format_source}",
        "format-muted": "у∞ЭЯ {format_source}",
        "format-source": "{volume}% пД∞",
        "format-source-muted": "пД±",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "у∞ЛЛ",
            "headset": "у∞ЛЛ",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "пА®"]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
    },
    "cpu": {
        "format": "{usage}% пЛЫ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% пГЙ"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}¬∞C {icon}",
        "format-icons": ["пЛЛ", "пЛЙ", "пЛЗ"]
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) пЗЂ",
        "format-ethernet": "{ipaddr}/{cidr} у∞ИА",
        "tooltip-format": "{ifname} via {gwaddr} у∞ИБ",
        "format-linked": "{ifname} (No IP) у∞ИБ",
        "format-disconnected": "Disconnected вЪ†",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% у∞ВД",
        "format-plugged": "{capacity}% пЗ¶",
        "format-alt": "{time} {icon}",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
        "format": "{:%m-%d %b %H:%M}",
        "tooltip-format": "{:%Y-%m-%d}",
        "format-alt": "{:%Y-%m-%d %B %H:%M}"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    }
}
